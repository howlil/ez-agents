{
  "$schema": "https://raw.githubusercontent.com/howlil/ez-agents/main/ez-agents/templates/config-schema.json",
  "version": "4.0.0",
  "logging": {
    "enabled": true,
    "level": "info",
    "profiling": false,
    "modules": {
      "adapters": "warn",
      "strategies": "error",
      "context": "info",
      "circuitBreaker": "warn",
      "decorators": "debug",
      "finops": "info",
      "analytics": "warn"
    },
    "tracePropagation": {
      "enabled": true,
      "format": "w3c-tracecontext"
    }
  },
  "provider": {
    "default": "qwen"
  }
}
