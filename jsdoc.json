{
  "source": {
    "include": [
      "bin",
      "ez-agents/bin/lib"
    ],
    "includePattern": ".+\\.c?js$",
    "excludePattern": "(node_modules|tests|coverage|deprecated)"
  },
  "plugins": [],
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  },
  "opts": {
    "destination": "./docs/generated",
    "encoding": "utf8",
    "recurse": true,
    "template": "./node_modules/ink-docstrap/template",
    "readme": "./README.md"
  },
  "markdown": {
    "hardwrap": false,
    "idPrefix": "doc_"
  },
  "linkStrategy": "Babel",
  "docstrap": {
    "theme": "united",
    "syntaxTheme": "default",
    "navType": "vertical",
    "date": "new Date()",
    "copyright": "EZ Agents - MIT License"
  }
}
