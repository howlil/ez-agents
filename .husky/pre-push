#!/usr/bin/env sh

# Pre-push hook: Run tests, check for secrets, validate planning files

echo "Running pre-push checks..."

# 1. Run tests
echo "→ Running tests..."
npm test --silent || {
  echo "❌ Tests failed! Push aborted."
  exit 1
}
echo "✓ Tests passed"

# 2. Check for potential secrets in staged files
echo "→ Checking for secrets..."
SECRETS_PATTERN='sk-[a-zA-Z0-9]{20,}|api_key\s*=\s*["\047][^"\047]+["\047]|password\s*=\s*["\047][^"\047]+["\047]'
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)

if [ -n "$STAGED_FILES" ]; then
  for file in $STAGED_FILES; do
    # Skip node_modules, tests, and example files
    case "$file" in
      node_modules/*|tests/*|*.example|*.sample|*.md) continue ;;
    esac
    
    if [ -f "$file" ] && grep -qE "$SECRETS_PATTERN" "$file" 2>/dev/null; then
      echo ""
      echo "⚠️  Potential secret found in: $file"
      echo "   Please remove sensitive data before pushing."
      echo "   Push aborted."
      exit 1
    fi
  done
fi
echo "✓ No secrets detected"

# 3. Validate planning files consistency
echo "→ Checking planning files..."
PLANNING_CHANGED=$(echo "$STAGED_FILES" | grep -c ".planning/" || true)

if [ "$PLANNING_CHANGED" -gt 0 ]; then
  # Check if STATE.md is included when other planning files changed
  STATE_CHANGED=$(echo "$STAGED_FILES" | grep -c ".planning/STATE.md" || true)
  PHASE_FILES_CHANGED=$(echo "$STAGED_FILES" | grep -cE ".planning/phases/.*-(PLAN|SUMMARY)\.md" || true)
  
  if [ "$PHASE_FILES_CHANGED" -gt 0 ] && [ "$STATE_CHANGED" -eq 0 ]; then
    echo ""
    echo "⚠️  Warning: Phase files changed but STATE.md not staged"
    echo "   Consider updating STATE.md to reflect phase progress"
    echo "   (This is a warning only, push will continue)"
  fi
fi
echo "✓ Planning files check complete"

echo ""
echo "✅ Pre-push checks passed! Pushing..."
exit 0
